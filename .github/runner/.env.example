# GitHub Runner Token (get from Settings > Actions > Runners > New self-hosted runner)
RUNNER_TOKEN=your-token-here

# Repository URL
REPO_URL=https://github.com/your-username/HyperInfer

# Runner name (optional)
RUNNER_NAME=hyperinfer-runner

# Path to GGUF models (only needed for Option 3 - fully containerized)
MODELS_DIR=/path/to/your/models