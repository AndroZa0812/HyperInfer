# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hyperinfer
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Server connection strings (auto-derived above, but can override)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/hyperinfer
# REDIS_URL=redis://localhost:6379

# Required secrets (must be set - generate with: openssl rand -hex 32)
ADMIN_TOKEN=
MCP_JWT_SECRET=

# Initial admin user (seeded on first startup if no admins exist)
# Leave blank to skip seeding; set email and a strong password before first run
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
SEED_TEAM_NAME=Default Team

# Rust log level (trace, debug, info, warn, error) - mapped to RUST_LOG in docker-compose
LOG_LEVEL=info

# Optional
ALLOWED_ORIGINS=http://localhost:3000
SERVER_PORT=3000

# Auth cookie settings
AUTH_COOKIE_SECURE=false  # Set to true in production with HTTPS